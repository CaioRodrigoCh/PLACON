<div class="interna">
  <h3><strong>Bem Vindo(a)!</strong></h3>
</div>

  <div class="interna">
    <div class="alert">
      <hr>  
          <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: 'form-signin form') do |f| %>
            <%= image_tag("ico40.png") %>
            <h1 class="h3 mb-3 font-weight-normal"><strong>PLACON</strong></h1>

            <div>
              <%= f.label :email %><br />
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-signin form' %>
            </div>

            <div>
              <a>Senha</a><br>
              <%= f.password_field :password, autocomplete: "current-password", class: 'form-signin form' %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div >
                <%= f.check_box :remember_me %>
                <%= f.label :Lembrar %>
              </div>
            <% end %>

            <br>

            <div>
              <%= f.submit "Entrar", class:'btn btn-primary' %>
            </div>
          <% end %>

          <br>

          <%= render "devise/shared/links" %>
    <%= render "layouts/partes/footer" %>
    </div>
  </div>
</body>
