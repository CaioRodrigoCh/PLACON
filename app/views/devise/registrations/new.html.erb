<div class="interna">
  <h2>Registrar-se</h2>
</div>


<div class="interna">
  <div class="alert">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: 'form-signin form') do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email %><br />
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-signin form' %>
      </div>

      <div class="field">
        <%= f.label :Senha %>
        <% if @minimum_password_length %>
        <em>(Mínimo <%= @minimum_password_length %> caracteres)</em>
        <% end %><br />
        <%= f.password_field :password, autocomplete: "new-password", class: 'form-signin form' %>
      </div>

      <div class="field">
        <%= f.label :Confime_a_Senha %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-signin form' %>
      </div>

      <br>
      <div class="actions">
        <%= f.submit "Registrar-se", class: 'btn btn-primary' %>
      </div>
    <% end %>

    <br>
    <%= render "devise/shared/links" %>
  </div>
</div>